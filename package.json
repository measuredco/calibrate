{
  "name": "calibrate",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "components:build": "pnpm --filter @measured/calibrate-components run build",
    "components:lint": "pnpm --filter @measured/calibrate-components run lint",
    "components:storybook": "pnpm --filter @measured/calibrate-components run storybook",
    "components:test": "pnpm --filter @measured/calibrate-components run test",
    "components:typecheck": "pnpm --filter @measured/calibrate-components run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tokens:build": "pnpm --filter @measured/calibrate-tokens run build",
    "tokens:validate": "pnpm --filter @measured/calibrate-tokens run validate",
    "tokens:verify": "pnpm --filter @measured/calibrate-tokens run verify"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "24.13.1"
  },
  "browserslist": [
    "extends @measured/calibrate-browserslist/browserslist-config"
  ],
  "devDependencies": {
    "@measured/calibrate-browserslist": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-storybook": "10.2.16",
    "globals": "^17.4.0",
    "prettier": "catalog:",
    "typescript-eslint": "^8.43.0"
  }
}
