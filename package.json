{
  "name": "calibrate",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "core:build": "pnpm --filter @measured/calibrate-core run build",
    "core:lint": "pnpm --filter @measured/calibrate-core run lint",
    "core:storybook": "pnpm --filter @measured/calibrate-core run storybook",
    "core:test": "pnpm --filter @measured/calibrate-core run test",
    "core:typecheck": "pnpm --filter @measured/calibrate-core run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "system:build": "pnpm --filter @measured/calibrate-system run build",
    "system:validate": "pnpm --filter @measured/calibrate-system run validate",
    "system:verify": "pnpm --filter @measured/calibrate-system run verify"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": "24.13.1"
  },
  "browserslist": [
    "extends @measured/calibrate-browserslist/browserslist-config"
  ],
  "devDependencies": {
    "@measured/calibrate-browserslist": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-storybook": "10.2.16",
    "globals": "^17.4.0",
    "prettier": "catalog:",
    "typescript-eslint": "^8.43.0"
  }
}
