{
  "$schema": "../../../../../schemas/2025.10/schema/format.json",
  "$description": "Semantic layout tokens for msrd tablet size context.",
  "container": {
    "gutter": {
      "$type": "dimension",
      "default": {
        "$value": "{spacing.horizontal.800}"
      },
      "sm": {
        "$value": "{spacing.horizontal.700}"
      }
    }
  },
  "grid": {
    "gap": {
      "$type": "dimension",
      "column": {
        "default": {
          "$value": "{spacing.horizontal.700}"
        },
        "lg": {
          "$value": "{grid.gap.column.default}"
        }
      },
      "row": {
        "default": {
          "$value": "{spacing.vertical.700}"
        },
        "lg": {
          "$value": "{grid.gap.row.default}"
        }
      }
    }
  }
}
