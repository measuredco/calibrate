{
  "$schema": "../../../../schemas/2025.10/format.json",
  "$description": "Semantic typography tokens that are not size-context-dependent.",
  "fontFamily": {
    "$type": "fontFamily",
    "default": {
      "$value": "{primitive.typography.fontFamily.sans}"
    },
    "mono": {
      "$value": "{primitive.typography.fontFamily.mono}"
    }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": {
      "$value": "{primitive.typography.fontWeight.400}"
    },
    "regularPlus": {
      "$value": "{primitive.typography.fontWeight.450}"
    },
    "medium": {
      "$value": "{primitive.typography.fontWeight.500}"
    },
    "bold": {
      "$value": "{primitive.typography.fontWeight.700}"
    }
  },
  "leading": {
    "700": {
      "$value": "{primitive.typography.leading.100}",
      "$description": "24"
    },
    "750": {
      "$value": "{primitive.typography.leading.133}",
      "$description": "27"
    },
    "775": {
      "$value": "{primitive.typography.leading.166}",
      "$description": "30"
    },
    "800": {
      "$value": "{primitive.typography.leading.200}",
      "$description": "36"
    },
    "850": {
      "$value": "{primitive.typography.leading.250}",
      "$description": "42"
    },
    "900": {
      "$value": "{primitive.typography.leading.300}",
      "$description": "48"
    },
    "925": {
      "$value": "{primitive.typography.leading.350}",
      "$description": "54"
    },
    "950": {
      "$value": "{primitive.typography.leading.400}",
      "$description": "60"
    },
    "1000": {
      "$value": "{primitive.typography.leading.500}",
      "$description": "72"
    },
    "1200": {
      "$value": "{primitive.typography.leading.600}",
      "$description": "96"
    },
    "1300": {
      "$value": "{primitive.typography.leading.700}",
      "$description": "120"
    },
    "$type": "dimension",
    "default": {
      "$value": "{leading.700}",
      "$description": "24"
    }
  },
  "measure": {
    "$type": "dimension",
    "default": {
      "$value": "{primitive.typography.measure.default}"
    },
    "tight": {
      "$value": "{primitive.typography.measure.sm}"
    }
  },
  "paragraph": {
    "spacing": {
      "$type": "dimension",
      "default": {
        "$value": "{spacing.vertical.700}"
      },
      "sm": {
        "$value": "{spacing.vertical.500}"
      },
      "lg": {
        "$value": "{spacing.vertical.800}"
      }
    }
  },
  "prose": {
    "link": {
      "decoration": {
        "thickness": {
          "$type": "dimension",
          "$value": "{layout.border.width.thick}"
        }
      },
      "hover": {
        "decoration": {
          "offset": {
            "$type": "dimension",
            "$value": "{primitive.typography.decorationOffset.100}"
          }
        }
      },
      "active": {
        "decoration": {
          "offset": {
            "$type": "dimension",
            "$value": "{primitive.typography.decorationOffset.150}"
          }
        }
      }
    }
  },
  "typeStep": {
    "100": {
      "$value": "{primitive.typography.typeStep.100}"
    },
    "200": {
      "$value": "{primitive.typography.typeStep.200}"
    },
    "300": {
      "$value": "{primitive.typography.typeStep.300}"
    },
    "400": {
      "$value": "{primitive.typography.typeStep.400}"
    },
    "450": {
      "$value": "{primitive.typography.typeStep.450}"
    },
    "500": {
      "$value": "{primitive.typography.typeStep.500}"
    },
    "600": {
      "$value": "{primitive.typography.typeStep.600}"
    },
    "700": {
      "$value": "{primitive.typography.typeStep.700}"
    },
    "800": {
      "$value": "{primitive.typography.typeStep.800}"
    },
    "900": {
      "$value": "{primitive.typography.typeStep.900}"
    },
    "1000": {
      "$value": "{primitive.typography.typeStep.1000}"
    },
    "1100": {
      "$value": "{primitive.typography.typeStep.1100}"
    },
    "1200": {
      "$value": "{primitive.typography.typeStep.1200}"
    },
    "1300": {
      "$value": "{primitive.typography.typeStep.1300}"
    },
    "default": {
      "$value": "{typeStep.200}"
    }
  }
}
