{
  "$description": "Semantic effect tokens for msrd light/default surface.",
  "opacity": {
    "$type": "number",
    "demoted": {
      "$value": "{primitive.effect.opacity.40}"
    }
  },
  "shadow": {
    "$type": "shadow",
    "default": {
      "$value": {
        "color": "{primitive.color.alpha.black.08}",
        "offsetX": "{primitive.effect.shadow.offsetX.100}",
        "offsetY": "{primitive.effect.shadow.offsetY.100}",
        "blur": "{primitive.effect.shadow.blur.100}",
        "spread": "{primitive.effect.shadow.spread.0}"
      }
    }
  }
}
