{
  "container": {
    "maxWidth": {
      "$type": "dimension",
      "lg": {
        "$value": {
          "value": 1280,
          "unit": "px"
        }
      },
      "xl": {
        "$value": {
          "value": 1440,
          "unit": "px"
        }
      }
    }
  },
  "focusRing": {
