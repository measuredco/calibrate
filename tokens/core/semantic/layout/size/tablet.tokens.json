{
  "$description": "Semantic layout tokens for msrd tablet size context.",
  "container": {
    "gutter": {
      "$type": "dimension",
      "default": {
        "$value": "{spacing.horizontal.800}"
      },
      "sm": {
        "$value": "{spacing.horizontal.700}"
      }
    }
  },
  "grid": {
    "gap": {
      "$type": "dimension",
      "default": {
        "column": {
          "$value": "{spacing.horizontal.700}"
        },
        "row": {
          "$value": "{spacing.vertical.700}"
        }
      },
      "lg": {
        "column": {
          "$value": "{grid.gap.default.column}"
        },
        "row": {
          "$value": "{grid.gap.default.row}"
        }
      }
    }
  }
}
