{
  "$schema": "../../../../schemas/2025.10/schema/format.json",
  "fontFamily": {
    "$type": "fontFamily",
    "default": {
      "$description": "Default font family. Use as the system's standard typeface.",
      "$value": "{primitive.typography.fontFamily.sans}"
    },
    "mono": {
      "$description": "Monospaced font family. Use for code and contexts where character-width consistency matters.",
      "$value": "{primitive.typography.fontFamily.mono}"
    }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": {
      "$description": "Regular font weight. Use as the system's standard text weight.",
      "$value": "{primitive.typography.fontWeight.400}"
    },
    "regularPlus": {
      "$description": "Slightly heavier regular font weight. Use for subtly emphasised text where bold would be too strong.",
      "$value": "{primitive.typography.fontWeight.450}"
    },
    "medium": {
      "$description": "Medium font weight. Use for medium text emphasis (e.g. medium headings).",
      "$value": "{primitive.typography.fontWeight.500}"
    },
    "bold": {
      "$description": "Bold font weight. Use for strong emphasis (semantic strong/bold elements, small headings).",
      "$value": "{primitive.typography.fontWeight.700}"
    }
  },
  "leading": {
    "$type": "dimension",
    "700": {
      "$description": "Default leading dimension. A block size representing the line-height; divide by font size to derive a CSS `line-height` ratio. Use as the body baseline.",
      "$value": "{primitive.typography.leading.100}"
    },
    "750": {
      "$description": "Leading step 750.",
      "$value": "{primitive.typography.leading.133}"
    },
    "775": {
      "$description": "Leading step 775.",
      "$value": "{primitive.typography.leading.166}"
    },
    "800": {
      "$description": "Leading step 800.",
      "$value": "{primitive.typography.leading.200}"
    },
    "850": {
      "$description": "Leading step 850.",
      "$value": "{primitive.typography.leading.250}"
    },
    "900": {
      "$description": "Leading step 900.",
      "$value": "{primitive.typography.leading.300}"
    },
    "925": {
      "$description": "Leading step 925.",
      "$value": "{primitive.typography.leading.350}"
    },
    "950": {
      "$description": "Leading step 950.",
      "$value": "{primitive.typography.leading.400}"
    },
    "1000": {
      "$description": "Leading step 1000. Comfortable for body prose.",
      "$value": "{primitive.typography.leading.500}"
    },
    "1200": {
      "$description": "Leading step 1200. Generous leading for spacious reading.",
      "$value": "{primitive.typography.leading.600}"
    },
    "1300": {
      "$description": "Leading step 1300. Looser leading for headings or low-density layouts.",
      "$value": "{primitive.typography.leading.700}"
    }
  },
  "measure": {
    "$type": "number",
    "default": {
      "$description": "Default measure (line length, in em). Use as the comfortable max-width to keep line lengths readable.",
      "$extensions": {
        "dev.msrd.calibrate.css": {
          "unit": "em"
        }
      },
      "$value": "{primitive.typography.measure.default}"
    },
    "tight": {
      "$description": "Tighter measure (line length, in em). A more constrained alternative to the default.",
      "$extensions": {
        "dev.msrd.calibrate.css": {
          "unit": "em"
        }
      },
      "$value": "{primitive.typography.measure.sm}"
    }
  },
  "paragraph": {
    "spacing": {
      "$type": "dimension",
      "default": {
        "$description": "Default vertical spacing between paragraphs.",
        "$value": "{primitive.spacing.900}"
      },
      "sm": {
        "$description": "Tighter paragraph spacing. Use in dense layouts or compact prose.",
        "$value": "{primitive.spacing.600}"
      },
      "lg": {
        "$description": "Looser paragraph spacing. Use in editorial layouts where extra breathing room aids reading.",
        "$value": "{primitive.spacing.1100}"
      }
    }
  },
  "prose": {
    "code": {
      "padding": {
        "block": {
          "default": {
            "$description": "Default block padding for inline code. Use for tight inline `code` spans.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.50}"
          },
          "lg": {
            "$description": "Larger block padding for inline code, used at larger viewports.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.200}"
          }
        },
        "inline": {
          "default": {
            "$description": "Inline (horizontal) padding for code spans.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.250}"
          }
        }
      }
    },
    "link": {
      "default": {
        "decoration": {
          "line": {
            "$description": "Default text-decoration line for prose links (none. Underline appears on hover only).",
            "$value": "{primitive.typography.decoration.line.none}"
          },
          "offset": {
            "$description": "Default underline offset for prose links, in em.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.100}"
          },
          "thickness": {
            "$description": "Default underline thickness for prose links.",
            "$type": "dimension",
            "$value": "{primitive.spacing.200}"
          }
        }
      },
      "hover": {
        "decoration": {
          "line": {
            "$description": "Text-decoration line for prose links on hover (underline).",
            "$value": "{primitive.typography.decoration.line.underline}"
          },
          "offset": {
            "$description": "Underline offset for prose links on hover, in em. Slightly increased from default for vidual effect.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.150}"
          }
        }
      },
      "active": {
        "decoration": {
          "offset": {
            "$description": "Underline offset for prose links during active (pressed) state, in em.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.200}"
          }
        }
      }
    }
  },
  "text": {
    "$type": "typography",
    "body": {
      "xs": {
        "$description": "Extra small body text. Use for the smallest body copy (footnotes, microtext). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.150.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.150.lineHeight}"
        }
      },
      "sm": {
        "$description": "Small body text. Use for secondary copy (captions, helper text) where default body would be too prominent. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.200.lineHeight}"
        }
      },
      "md": {
        "$description": "Default body text size. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.300.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.300.lineHeight}"
        }
      },
      "lg": {
        "$description": "Large body text. Use for emphasised copy (intro paragraphs, lede text). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.400.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.400.lineHeight}"
        }
      }
    },
    "heading": {
      "xs": {
        "$description": "Extra small heading (h6-equivalent). Use for subsection labels and sidebar titles. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.650}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.200.lineHeight}"
        }
      },
      "sm": {
        "$description": "Small heading (h5-equivalent). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.300.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.600}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.300.lineHeight}"
        }
      },
      "md": {
        "$description": "Medium heading (h4-equivalent). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.400.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.500}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.400.lineHeight}"
        }
      },
      "lg": {
        "$description": "Large heading (h3-equivalent). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.500.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.450}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.500.lineHeight}"
        }
      },
      "xl": {
        "$description": "Extra large heading (h2-equivalent). Use for section headings. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.700.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.700.lineHeight}"
        }
      },
      "2xl": {
        "$description": "2xl heading (h1-equivalent). Use for page titles. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.900.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.350}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.900.lineHeight}"
        }
      },
      "3xl": {
        "$description": "Display heading (3xl). Use for hero/marketing headings. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1000.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.300}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1000.lineHeight}"
        }
      },
      "4xl": {
        "$description": "Display heading (4xl). Use for very large display headings. Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1100.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.250}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1100.lineHeight}"
        }
      },
      "5xl": {
        "$description": "Display heading (5xl). Use for the largest display headings (statement marketing pages). Fixed size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.200}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1200.lineHeight}"
        }
      }
    }
  },
  "typeStep": {
    "50": {
      "fontSize": {
        "$description": "Type-step 50 font size. Smallest step in the type scale.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.50.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 50 line height. Pairs with type-step 50 font size.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.50.lineHeight}"
      }
    },
    "100": {
      "fontSize": {
        "$description": "Type-step 100 font size. Tight-leading variant.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.100.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 100 line height. Tight leading.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.100.lineHeight}"
      }
    },
    "150": {
      "fontSize": {
        "$description": "Type-step 150 font size. Loose-leading variant of step 100.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.150.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 150 line height. Loose leading.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.150.lineHeight}"
      }
    },
    "200": {
      "fontSize": {
        "$description": "Type-step 200 font size. Small-body equivalent. Use as the default type-step font size in compositions that need explicit size/leading control.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.200.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 200 line height. Pairs with the default type-step font size.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.200.lineHeight}"
      }
    },
    "300": {
      "fontSize": {
        "$description": "Type-step 300 font size. Body-equivalent.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.300.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 300 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.300.lineHeight}"
      }
    },
    "400": {
      "fontSize": {
        "$description": "Type-step 400 font size. Large-body / small-heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.400.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 400 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.400.lineHeight}"
      }
    },
    "450": {
      "fontSize": {
        "$description": "Type-step 450 font size. Medium-heading equivalent.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.450.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 450 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.450.lineHeight}"
      }
    },
    "500": {
      "fontSize": {
        "$description": "Type-step 500 font size. Heading equivalent.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.500.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 500 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.500.lineHeight}"
      }
    },
    "600": {
      "fontSize": {
        "$description": "Type-step 600 font size. Large heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.600.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 600 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.600.lineHeight}"
      }
    },
    "700": {
      "fontSize": {
        "$description": "Type-step 700 font size. Extra-large heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.700.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 700 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.700.lineHeight}"
      }
    },
    "800": {
      "fontSize": {
        "$description": "Type-step 800 font size.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.800.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 800 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.800.lineHeight}"
      }
    },
    "900": {
      "fontSize": {
        "$description": "Type-step 900 font size. Page-title equivalent.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.900.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 900 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.900.lineHeight}"
      }
    },
    "1000": {
      "fontSize": {
        "$description": "Type-step 1000 font size. Display heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.1000.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 1000 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.1000.lineHeight}"
      }
    },
    "1100": {
      "fontSize": {
        "$description": "Type-step 1100 font size. Large display heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.1100.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 1100 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.1100.lineHeight}"
      }
    },
    "1200": {
      "fontSize": {
        "$description": "Type-step 1200 font size. Very large display heading.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.1200.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 1200 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.1200.lineHeight}"
      }
    },
    "1300": {
      "fontSize": {
        "$description": "Type-step 1300 font size. Largest step in the type scale.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.1300.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 1300 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.1300.lineHeight}"
      }
    }
  }
}
