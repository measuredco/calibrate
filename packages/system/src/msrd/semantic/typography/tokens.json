{
  "$schema": "../../../../schemas/2025.10/schema/format.json",
  "fontFamily": {
    "$type": "fontFamily",
    "default": {
      "$description": "Default font family. Use as the system's standard typeface.",
      "$value": "{primitive.typography.fontFamily.sans}"
    },
    "mono": {
      "$description": "Monospaced font family. Use for code, contexts where character-width consistency matters (e.g. avatar, badge), and occasional typographic flourishes.",
      "$value": "{primitive.typography.fontFamily.mono}"
    }
  },
  "fontWeight": {
    "$type": "fontWeight",
    "regular": {
      "$description": "Regular font weight. Use as the system's standard text weight.",
      "$value": "{primitive.typography.fontWeight.400}"
    },
    "regularPlus": {
      "$description": "Slightly heavier regular font weight. Use for subtly emphasised text where bold would be too strong.",
      "$value": "{primitive.typography.fontWeight.450}"
    },
    "medium": {
      "$description": "Medium font weight. Use for medium text emphasis (e.g. medium headings).",
      "$value": "{primitive.typography.fontWeight.500}"
    },
    "bold": {
      "$description": "Bold font weight. Use for strong text emphasis (semantic `strong`/`b` elements, small headings).",
      "$value": "{primitive.typography.fontWeight.700}"
    }
  },
  "leading": {
    "$type": "dimension",
    "700": {
      "$description": "Default leading dimension. A block size representing the line-height; divide by font size to derive a line-height ratio. An escape hatch for aligning line-heights across elements with different font sizes (e.g. a small counter beside a large heading) — reach for text composites or typeStep pairs first.",
      "$value": "{primitive.typography.leading.100}"
    },
    "750": {
      "$description": "Leading step 750.",
      "$value": "{primitive.typography.leading.133}"
    },
    "775": {
      "$description": "Leading step 775.",
      "$value": "{primitive.typography.leading.166}"
    },
    "800": {
      "$description": "Leading step 800.",
      "$value": "{primitive.typography.leading.200}"
    },
    "850": {
      "$description": "Leading step 850.",
      "$value": "{primitive.typography.leading.250}"
    },
    "900": {
      "$description": "Leading step 900.",
      "$value": "{primitive.typography.leading.300}"
    },
    "925": {
      "$description": "Leading step 925.",
      "$value": "{primitive.typography.leading.350}"
    },
    "950": {
      "$description": "Leading step 950.",
      "$value": "{primitive.typography.leading.400}"
    },
    "1000": {
      "$description": "Leading step 1000.",
      "$value": "{primitive.typography.leading.500}"
    },
    "1200": {
      "$description": "Leading step 1200.",
      "$value": "{primitive.typography.leading.600}"
    },
    "1300": {
      "$description": "Leading step 1300.",
      "$value": "{primitive.typography.leading.700}"
    }
  },
  "measure": {
    "$type": "number",
    "default": {
      "$description": "Default measure (line length, in em). Use as the comfortable maximum width to keep line lengths readable.",
      "$extensions": {
        "dev.msrd.calibrate.css": {
          "unit": "em"
        }
      },
      "$value": "{primitive.typography.measure.default}"
    },
    "tight": {
      "$description": "Tighter measure (line length, in em). A more constrained alternative to the default.",
      "$extensions": {
        "dev.msrd.calibrate.css": {
          "unit": "em"
        }
      },
      "$value": "{primitive.typography.measure.sm}"
    }
  },
  "paragraph": {
    "spacing": {
      "$type": "dimension",
      "default": {
        "$description": "Default vertical spacing between paragraphs.",
        "$value": "{primitive.spacing.900}"
      },
      "sm": {
        "$description": "Tighter paragraph spacing. Use in dense layouts or compact prose.",
        "$value": "{primitive.spacing.600}"
      },
      "lg": {
        "$description": "Looser paragraph spacing. Use in editorial layouts where extra breathing room aids reading.",
        "$value": "{primitive.spacing.1100}"
      }
    }
  },
  "prose": {
    "code": {
      "padding": {
        "block": {
          "default": {
            "$description": "Default block padding for inline `code`. Use at smaller viewports.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.50}"
          },
          "lg": {
            "$description": "Larger block padding for inline `code`. Use at larger viewports.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.200}"
          }
        },
        "inline": {
          "default": {
            "$description": "Inline (horizontal) padding for inline `code`.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.code.padding.250}"
          }
        }
      }
    },
    "link": {
      "default": {
        "decoration": {
          "line": {
            "$description": "Default decoration line for prose links.",
            "$value": "{primitive.typography.decoration.line.none}"
          },
          "offset": {
            "$description": "Default decoration offset for prose links, in em.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.100}"
          },
          "thickness": {
            "$description": "Default decoration thickness for prose links.",
            "$type": "dimension",
            "$value": "{primitive.spacing.200}"
          }
        }
      },
      "hover": {
        "decoration": {
          "line": {
            "$description": "Decoration line for prose links on hover.",
            "$value": "{primitive.typography.decoration.line.underline}"
          },
          "offset": {
            "$description": "Decoration offset for prose links on hover, in em.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.150}"
          }
        }
      },
      "active": {
        "decoration": {
          "offset": {
            "$description": "Decoration offset for prose links during active (pressed) state, in em.",
            "$type": "number",
            "$extensions": {
              "dev.msrd.calibrate.css": {
                "unit": "em"
              }
            },
            "$value": "{primitive.typography.decoration.offset.200}"
          }
        }
      }
    }
  },
  "text": {
    "$type": "typography",
    "body": {
      "xs": {
        "$description": "Extra small body text. Use for the smallest body copy (microtext).",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.150.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.150.lineHeight}"
        }
      },
      "sm": {
        "$description": "Small body text. Use for secondary copy (labels, captions, helper text) where default body would be too prominent.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.200.lineHeight}"
        }
      },
      "md": {
        "$description": "Default body text size.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.300.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.300.lineHeight}"
        }
      },
      "lg": {
        "$description": "Large body text. Use for emphasised copy (intro paragraphs, lede text).",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.400.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.400.lineHeight}"
        }
      }
    },
    "heading": {
      "xs": {
        "$description": "Extra small heading (`h6`-equivalent). Use for subsection headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.650}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.200.lineHeight}"
        }
      },
      "sm": {
        "$description": "Small heading (`h5`-equivalent). Use for subsection headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.300.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.600}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.300.lineHeight}"
        }
      },
      "md": {
        "$description": "Medium heading (`h4`-equivalent). Use for subsection headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.400.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.500}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.400.lineHeight}"
        }
      },
      "lg": {
        "$description": "Large heading (`h3`-equivalent). Use for subsection headings and component-level titles (cards, panels).",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.500.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.450}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.500.lineHeight}"
        }
      },
      "xl": {
        "$description": "Extra large heading (`h2`-equivalent). Use for section headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.700.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.400}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.700.lineHeight}"
        }
      },
      "2xl": {
        "$description": "2xl heading (`h1`-equivalent). Use for page titles.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.900.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.350}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.900.lineHeight}"
        }
      },
      "3xl": {
        "$description": "Display heading (3xl). Use for hero/marketing headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1000.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.300}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1000.lineHeight}"
        }
      },
      "4xl": {
        "$description": "Display heading (4xl). Use for larger hero/marketing headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1100.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.250}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1100.lineHeight}"
        }
      },
      "5xl": {
        "$description": "Display heading (5xl). Use for the largest hero/marketing headings.",
        "$value": {
          "fontFamily": "{primitive.typography.fontFamily.sans}",
          "fontSize": "{primitive.typography.typeStep.1200.fontSize}",
          "fontWeight": "{primitive.typography.fontWeight.200}",
          "letterSpacing": "{primitive.typography.letterSpacing.0}",
          "lineHeight": "{primitive.typography.typeStep.1200.lineHeight}"
        }
      }
    }
  },
  "typeStep": {
    "50": {
      "fontSize": {
        "$description": "Type-step 50 font size. Smallest step.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.50.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 50 line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.50.lineHeight}"
      }
    },
    "100": {
      "fontSize": {
        "$description": "Type-step 100 font size. Tight-leading variant.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.100.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 100 line height. Tight leading.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.100.lineHeight}"
      }
    },
    "150": {
      "fontSize": {
        "$description": "Type-step 150 font size. Loose-leading variant of step 100.",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.150.fontSize}"
      },
      "lineHeight": {
        "$description": "Type-step 150 line height. Loose leading.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.150.lineHeight}"
      }
    },
    "200": {
      "fontSize": {
        "$description": "Default type-step font size. Type-steps are size/leading pairs for explicit typographic control without a full text composite (body/heading).",
        "$type": "dimension",
        "$value": "{primitive.typography.typeStep.200.fontSize}"
      },
      "lineHeight": {
        "$description": "Default type-step line height.",
        "$type": "number",
        "$value": "{primitive.typography.typeStep.200.lineHeight}"
      }
    },
    "300": {
      "fontSize": {
        "$description": "Type-step 300 font size.",
        "$type": "dimension",
