{
  "$schema": "../../../../schemas/2025.10/schema/format.json",
  "border": {
    "width": {
      "$type": "dimension",
      "default": {
        "$value": "{primitive.spacing.100}"
      },
      "thick": {
        "$value": "{primitive.spacing.200}"
      }
    }
  },
  "container": {
    "maxWidth": {
      "$type": "dimension",
      "lg": {
        "$value": "{primitive.layout.container.maxWidth.lg}"
      },
      "xl": {
        "$value": "{primitive.layout.container.maxWidth.xl}"
      }
    }
  },
  "focusRing": {
    "offset": {
      "$type": "dimension",
      "default": {
        "$value": "{primitive.layout.focusRing.offset.default}"
      },
      "inset": {
        "$value": "{primitive.layout.focusRing.offset.inset}"
      }
    },
    "width": {
      "$type": "dimension",
      "$value": "{border.width.thick}"
    }
  },
  "grid": {
    "columns": {
      "$type": "number",
      "$value": "{primitive.layout.grid.columns}"
    },
    "item": {
      "minWidth": {
        "$type": "dimension",
        "$value": "{primitive.layout.grid.item.minWidth}"
      }
    }
  },
  "icon": {
    "size": {
      "$type": "dimension",
      "default": {
        "$value": "{primitive.spacing.900}"
      },
      "sm": {
        "$value": "{primitive.spacing.800}"
      }
    }
  }
}
