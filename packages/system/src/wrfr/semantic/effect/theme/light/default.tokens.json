{
  "$schema": "../../../../../../schemas/2025.10/schema/format.json",
  "opacity": {
    "$type": "number",
    "disabled": {
      "$value": "{primitive.effect.opacity.40}"
    },
    "demoted": {
      "$value": "{primitive.effect.opacity.40}"
    }
  },
  "shadow": {
    "$type": "shadow",
    "default": {
      "$value": {
        "color": "{primitive.color.alpha.black.08}",
        "offsetX": "{primitive.effect.shadow.offsetX.100}",
        "offsetY": "{primitive.effect.shadow.offsetY.100}",
        "blur": "{primitive.effect.shadow.blur.100}",
        "spread": "{primitive.effect.shadow.spread.0}"
      }
    }
  },
  "stroke": {
    "$type": "dimension",
    "inset": {
      "$value": "{primitive.effect.stroke.inset}"
    },
    "outset": {
      "$value": "{primitive.effect.stroke.outset}"
    }
  },
  "filter": {
    "image": {
      "$value": "{primitive.effect.filter.grayscale.100}"
    }
  }
}
