    "autoprefixer": "^10.4.21",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "catalog:",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^4.0.18"
  }
