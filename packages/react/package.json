{
  "name": "@measured/calibrate-react",
  "version": "0.1.1-alpha.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/measuredco/calibrate.git",
    "directory": "packages/react"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "prebuild": "pnpm --filter @measured/calibrate-adapter run generate:react",
    "build": "vite build && pnpm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@measured/calibrate-core": "workspace:*"
  },
  "devDependencies": {
    "@measured/calibrate-adapter": "workspace:*",
    "@measured/calibrate-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
