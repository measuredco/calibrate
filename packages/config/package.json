{
  "name": "@measured/calibrate-config",
  "version": "0.2.0-alpha.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/measuredco/calibrate.git",
    "directory": "packages/config"
  },
  "type": "module",
  "files": [
    "index.mjs",
    "index.d.ts",
    "esbuild.mjs",
    "esbuild.d.ts",
    "eslint.mjs",
    "eslint.d.ts",
    "stylelint.mjs",
    "stylelint.d.ts",
    "README.md"
  ],
  "types": "./index.d.ts",
  "exports": {
    "./browserslist": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./browserslist/esbuild": {
      "types": "./esbuild.d.ts",
      "default": "./esbuild.mjs"
    },
    "./eslint": {
      "types": "./eslint.d.ts",
      "default": "./eslint.mjs"
    },
    "./stylelint": {
      "types": "./stylelint.d.ts",
      "default": "./stylelint.mjs"
    }
  },
  "browserslist": [
    "baseline widely available"
  ],
  "dependencies": {
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "stylelint": "^17.0.0"
  }
}
